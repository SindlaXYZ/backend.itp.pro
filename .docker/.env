DKZ_ENV=DEV
DKZ_RUN_RESTART=no
DKZ_DIST=debian:13.3
DKZ_SHARED_MEMORY=512m
DKZ_DOMAIN=backend.itp.pro
DKZ_DOMAINS=backend.itp.pro
DKZ_NAME=backend_itp_pro
DKZ_SELF_MODIFY=1
DKZ_PORT_PREFIX=2011
DKZ_SHARED_PORTS=
DKZ_GIT_REPO_URI=git@github.com:SindlaXYZ/backend.itp.pro.git
DKZ_GIT_BRANCH_DEVELOPMENT=main
DKZ_GIT_BRANCH_STAGING=staging
DKZ_GIT_BRANCH_PRODUCTION=main
DKZ_NGINX_INSTALL=1
DKZ_NGINX_BASIC_ACCESS_AUTHENTICATION_USERNAME=
DKZ_NGINX_BASIC_ACCESS_AUTHENTICATION_PASSWORD=
DKZ_PHP_VERSION_INSTALL=8.5
DKZ_PHP_PRELOAD=
DKZ_PHP_XDEBUG=1
DKZ_PHP_MAX_EXECUTION_TIME=30
DKZ_PHP_MAX_INPUT_VARS=1000
DKZ_PHP_MEMORY_LIMIT=1024M
DKZ_PHP_CLI_MEMORY_LIMIT=2048M
DKZ_PHP_RESTART_IF_BAD_DOMAIN_STATUS_CODE=0
DKZ_PHP_RESTART_IF_NOT_STATUS_CODE="(200 301 302 307 308 500)"
DKZ_PHP_SYMFONY_VERSION_INSTALL=8.0
DKZ_PHP_SYMFONY_API_PLATFORM_VERSION_INSTALL=4.3
DKZ_PHP_SYMFONY_AURORA_INSTALL=1
DKZ_POSTGRESQL_VERSION_INSTALL=18
DKZ_POSTGRESQL_HOSTNAME="/var/run/postgresql"
DKZ_POSTGRESQL_USERNAME=backend_itp_pro
DKZ_POSTGRESQL_PASSWORD=backend_itp_pro
DKZ_POSTGRESQL_DATABASE=backend_itp_pro
DKZ_POSTGRESQL_BACKUP_INTERVAL=0
DKZ_POSTGRESQL_BACKUP_FORMAT=7zip
DKZ_MYSQL_VERSION_INSTALL=0
DKZ_MYSQL_USERNAME=
DKZ_MYSQL_PASSWORD=
DKZ_MYSQL_DATABASE=
DKZ_MYSQL_BACKUP_INTERVAL=0
DKZ_MYSQL_BACKUP_FORMAT=7zip
DKZ_CERTBOT_INSTALL=0
DKZ_NODEJS_INSTALL=0
DKZ_NODEJS_ANGULAR_PORT=4000
DKZ_NODEJS_ANGULAR_VERSION_INSTALL=0
DKZ_AI_CODEX_INSTALL=0
DKZ_AI_GEMINI_INSTALL=0
DKZ_AI_CLAUDE_CODE_INSTALL=1
DKZ_MEMCACHED_INSTALL=0
DKZ_MONGODB_INSTALL=0
DKZ_RABBITMQ_INSTALL=0
DKZ_ADMINER_PASSWORD=__ADMINER_PASSWORD__
DKZ_MAXMIND_LICENSE_KEY=__MAXMIND_LICENSE_KEY__
